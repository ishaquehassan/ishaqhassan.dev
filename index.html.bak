    </div>
    <div class="dock-item" onclick="openWindow('articles')">
      <div class="dock-tooltip">Articles</div>
      <div class="dock-icon articles"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M4 4h16a2 2 0 012 2v12a2 2 0 01-2 2H4a2 2 0 01-2-2V6a2 2 0 012-2z" stroke="#fff" stroke-width="1.5"/><path d="M7 8h10M7 12h6" stroke="#fff" stroke-width="1.5" stroke-linecap="round"/></svg></div>
    </div>
    <div class="dock-item" onclick="openWindow('contact')">
      <div class="dock-tooltip">Contact</div>
      <div class="dock-icon contact"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="2" y="4" width="20" height="16" rx="2" stroke="#fff" stroke-width="1.5"/><path d="M22 6l-10 7L2 6" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
    </div>
